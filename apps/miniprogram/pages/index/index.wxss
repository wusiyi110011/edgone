.page {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero,
.card,
.metric-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  border: 2rpx solid rgba(110, 149, 177, 0.14);
  box-shadow: 0 18rpx 40rpx rgba(32, 76, 116, 0.08);
}

.hero,
.card {
  padding: 28rpx;
}

.eyebrow {
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: #5380a3;
}

.title {
  display: block;
  margin-top: 14rpx;
  font-size: 44rpx;
  line-height: 1.16;
  font-weight: 700;
  color: #17344e;
}

.desc,
.tips text {
  display: block;
  margin-top: 14rpx;
  color: #55718a;
  font-size: 28rpx;
  line-height: 1.6;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.metric-card {
  padding: 24rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.metric-value {
  font-size: 46rpx;
  font-weight: 800;
  color: #1c3b57;
}

.metric-label {
  color: #64819b;
  font-size: 24rpx;
}

.label,
.section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #4d6c87;
}

.name-input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(113, 149, 173, 0.24);
  background: #f9fcff;
}

.start-button {
  margin-top: 20rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #165685, #2b7bb0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.error-text {
  display: block;
  margin-top: 18rpx;
  color: #b4444e;
  font-size: 24rpx;
}
